# ═══════════════════════════════════════════════════════════════
#  .env.example — Template variables d'environnement
#  Copier en .env.secrets et remplir les vraies valeurs
#  ⚠️  Ne JAMAIS commiter .env.secrets dans Git
# ═══════════════════════════════════════════════════════════════

# ─── Harbor Registry ─────────────────────────────────────────────
HARBOR_HOST=harbor.monorg.com
HARBOR_USER=jenkins-ci
HARBOR_PASSWORD=CHANGER_MOI
HARBOR_REGISTRY=harbor.monorg.com/devsecops

# ─── Application ─────────────────────────────────────────────────
ENV=production
APP_VERSION=1.0.0
SECRET_KEY=CHANGER_MOI_CLE_LONGUE_ET_ALEATOIRE
ALLOWED_ORIGINS=https://mondomaine.com

# ─── Déploiement SSH ─────────────────────────────────────────────
DEPLOY_HOST=192.168.1.100
DEPLOY_USER=deploy

# ─── Monitoring ──────────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGER_MOI

# ─── Notifications ───────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGER/MOI
